@page "/dashboard"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using AspendoraFileShare.Data
@using AspendoraFileShare.Services
@using Microsoft.EntityFrameworkCore
@using Microsoft.JSInterop
@attribute [Authorize]
@inject ApplicationDbContext DbContext
@inject AuthService AuthService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IJSRuntime JSRuntime

<PageTitle>Dashboard - Aspendora File Share</PageTitle>

<div class="min-h-screen bg-gray-50">
    <!-- Header -->
    <header class="bg-white border-b-2 border-[#660000] shadow-sm">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
            <div class="flex items-center justify-between">
                <div class="flex items-center gap-4">
                    <img src="/aspendora-logo.png" alt="Aspendora Technologies" class="h-12 w-auto" />
                    <div>
                        <h1 class="text-2xl font-bold text-[#660000]">Aspendora File Share</h1>
                        <p class="text-sm text-gray-600 mt-1">Welcome, @userName</p>
                    </div>
                </div>
                <div class="flex items-center gap-4">
                    @if (isAdmin)
                    {
                        <a href="/admin" class="text-[#660000] hover:text-black font-medium text-sm">
                            Admin Panel
                        </a>
                    }
                    <a href="/Account/SignOut"
                       class="px-4 py-2 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 transition-colors text-sm font-medium inline-block">
                        Sign Out
                    </a>
                </div>
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="space-y-8">
            <!-- Instructions -->
            <div class="bg-white border-2 border-[#660000] rounded-lg p-6">
                <h2 class="text-xl font-semibold text-gray-900 mb-4">Share Files</h2>
                <div class="space-y-2 text-gray-600">
                    <p class="flex items-start gap-2">
                        <span class="text-[#660000] font-bold">1.</span>
                        <span>Upload your files (up to 50GB each)</span>
                    </p>
                    <p class="flex items-start gap-2">
                        <span class="text-[#660000] font-bold">2.</span>
                        <span>Add recipient email and optional message</span>
                    </p>
                    <p class="flex items-start gap-2">
                        <span class="text-[#660000] font-bold">3.</span>
                        <span>Send! Link expires in 30 days</span>
                    </p>
                </div>
            </div>

            <!-- File Uploader -->
            <FileUpload OnUploadComplete="HandleUploadComplete" />

            <!-- Recent Shares -->
            <div class="bg-white border-2 border-[#660000] rounded-lg p-6">
                <h2 class="text-xl font-semibold text-gray-900 mb-4">Recent Shares</h2>

                @if (isLoadingShares)
                {
                    <p class="text-gray-500 text-sm">Loading...</p>
                }
                else if (shares == null || !shares.Any())
                {
                    <p class="text-gray-500 text-sm">Your recent file shares will appear here</p>
                }
                else
                {
                    <div class="space-y-4">
                        @foreach (var share in shares)
                        {
                            var shareUrl = $"{Navigation.BaseUri}s/{share.ShortId}";
                            <div class="border border-gray-200 rounded-lg p-4 hover:bg-gray-50 transition-colors">
                                <div class="flex items-start justify-between">
                                    <div class="flex-1">
                                        <div class="flex items-center gap-2 mb-2">
                                            <span class="font-medium text-gray-900">
                                                @share.FileCount @(share.FileCount == 1 ? "file" : "files")
                                            </span>
                                            <span class="text-gray-400">•</span>
                                            <span class="text-sm text-gray-600">@FormatBytes(share.TotalSize)</span>
                                            @if (!string.IsNullOrEmpty(share.RecipientEmail))
                                            {
                                                <span class="text-gray-400">•</span>
                                                <span class="text-sm text-gray-600">to @(share.RecipientName ?? share.RecipientEmail)</span>
                                            }
                                        </div>
                                        <div class="text-sm text-gray-500 mb-2">
                                            Created @share.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy") •
                                            Expires @share.ExpiresAt.ToLocalTime().ToString("MMM dd, yyyy")
                                        </div>
                                        <div class="flex items-center gap-2 text-sm">
                                            <span class="text-gray-600">Downloads: @share.Downloads</span>
                                        </div>
                                    </div>
                                    <div class="flex items-center gap-2">
                                        <button @onclick="() => CopyLink(share.ShortId)"
                                                class="px-3 py-1.5 bg-[#660000] text-white rounded hover:bg-black transition-colors text-sm font-medium whitespace-nowrap">
                                            Copy Link
                                        </button>
                                        <button @onclick="() => OpenResendModal(share.ShortId)"
                                                class="px-3 py-1.5 text-white rounded transition-colors text-sm font-medium whitespace-nowrap"
                                                style="background-color: #2563eb;"
                                                onmouseover="this.style.backgroundColor='#1d4ed8'"
                                                onmouseout="this.style.backgroundColor='#2563eb'">
                                            Resend
                                        </button>
                                        <button @onclick="() => DeleteShare(share.Id)"
                                                class="px-3 py-1.5 bg-red-600 text-white rounded hover:bg-red-700 transition-colors text-sm font-medium whitespace-nowrap">
                                            Delete
                                        </button>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </main>
</div>

<!-- Share Modal -->
<ShareModal IsVisible="@showShareModal"
            ShortId="@uploadedShortId"
            OnClose="HandleShareModalClose" />

<!-- Resend Email Modal -->
@if (showResendModal)
{
    <div class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center p-4 z-50">
        <div class="bg-white rounded-lg max-w-md w-full p-6">
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-xl font-bold text-[#660000]">Resend Share Link</h2>
                <button @onclick="CloseResendModal" class="text-gray-400 hover:text-gray-600">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </button>
            </div>

            <div class="space-y-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Recipient Email(s)</label>
                    <textarea @bind="resendEmails"
                              placeholder="recipient1@example.com, recipient2@example.com"
                              rows="2"
                              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#660000] focus:border-transparent"></textarea>
                    <p class="text-xs text-gray-500 mt-1">Separate multiple email addresses with commas</p>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Message (Optional)</label>
                    <textarea @bind="resendMessage"
                              placeholder="Add a personal message..."
                              rows="3"
                              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#660000] focus:border-transparent"></textarea>
                </div>

                @if (!string.IsNullOrEmpty(resendError))
                {
                    <div class="p-3 bg-red-50 border border-red-200 rounded-lg">
                        <p class="text-red-800 text-sm">@resendError</p>
                    </div>
                }

                @if (resendSuccess)
                {
                    <div class="p-3 bg-green-50 border border-green-200 rounded-lg">
                        <p class="text-green-800 text-sm">Emails sent successfully!</p>
                    </div>
                }

                <div class="flex gap-3">
                    <button @onclick="SendResendEmails"
                            disabled="@(isResending || string.IsNullOrWhiteSpace(resendEmails))"
                            class="flex-1 bg-[#660000] text-white py-2 px-4 rounded-lg font-semibold hover:bg-black disabled:opacity-50 disabled:cursor-not-allowed">
                        @(isResending ? "Sending..." : "Send")
                    </button>
                    <button @onclick="CloseResendModal"
                            class="px-4 py-2 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300">
                        Cancel
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private string userName = "";
    private bool isAdmin = false;
    private List<ShareDto>? shares;
    private bool isLoadingShares = true;

    // Upload result handling
    private bool showShareModal = false;
    private string uploadedShortId = "";

    // Resend modal state
    private bool showResendModal = false;
    private string resendShortId = "";
    private string resendEmails = "";
    private string resendMessage = "";
    private bool isResending = false;
    private string? resendError;
    private bool resendSuccess = false;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            var dbUser = await AuthService.GetOrCreateUserAsync(user);
            userName = dbUser.Name ?? dbUser.Email;
            isAdmin = await AuthService.IsAdminAsync(user);

            await LoadShares(dbUser.Id);
        }
    }

    private async Task LoadShares(string userId)
    {
        isLoadingShares = true;

        shares = await DbContext.ShareLinks
            .Include(s => s.Files)
            .Where(s => s.UserId == userId && !s.Deleted)
            .OrderByDescending(s => s.CreatedAt)
            .Take(50)
            .Select(s => new ShareDto
            {
                Id = s.Id,
                ShortId = s.ShortId,
                RecipientEmail = s.RecipientEmail,
                RecipientName = s.RecipientName,
                CreatedAt = s.CreatedAt,
                ExpiresAt = s.ExpiresAt,
                Downloads = s.Downloads,
                FileCount = s.Files.Count,
                TotalSize = s.Files.Sum(f => f.FileSize)
            })
            .ToListAsync();

        isLoadingShares = false;
    }

    private Task HandleUploadComplete(FileUpload.UploadResult result)
    {
        if (result.Success && !string.IsNullOrEmpty(result.ShortId))
        {
            uploadedShortId = result.ShortId;
            showShareModal = true;
        }
        return Task.CompletedTask;
    }

    private async Task HandleShareModalClose()
    {
        showShareModal = false;
        uploadedShortId = "";

        // Refresh shares list
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            var dbUser = await AuthService.GetOrCreateUserAsync(user);
            await LoadShares(dbUser.Id);
        }

        StateHasChanged();
    }

    private async Task CopyLink(string shortId)
    {
        var url = $"{Navigation.BaseUri}s/{shortId}";
        try
        {
            var success = await JSRuntime.InvokeAsync<bool>("clipboardInterop.copyToClipboard", url);
            if (success)
            {
                await JSRuntime.InvokeVoidAsync("clipboardInterop.showToast", "Link copied to clipboard!", "success");
            }
        }
        catch (Exception)
        {
            await JSRuntime.InvokeVoidAsync("clipboardInterop.showToast", "Failed to copy link", "error");
        }
    }

    private async Task DeleteShare(string shareId)
    {
        // Confirm deletion
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm",
            "Are you sure you want to delete this share? This will permanently delete all files and the share link.");

        if (!confirmed) return;

        try
        {
            var response = await new HttpClient { BaseAddress = new Uri(Navigation.BaseUri) }
                .PostAsJsonAsync("/api/share/delete", new { ShareId = shareId });

            if (response.IsSuccessStatusCode)
            {
                await JSRuntime.InvokeVoidAsync("clipboardInterop.showToast", "Share deleted successfully", "success");

                // Refresh shares
                var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
                var user = authState.User;
                if (user.Identity?.IsAuthenticated == true)
                {
                    var dbUser = await AuthService.GetOrCreateUserAsync(user);
                    await LoadShares(dbUser.Id);
                }

                StateHasChanged();
            }
            else
            {
                await JSRuntime.InvokeVoidAsync("clipboardInterop.showToast", "Failed to delete share", "error");
            }
        }
        catch (Exception)
        {
            await JSRuntime.InvokeVoidAsync("clipboardInterop.showToast", "Failed to delete share", "error");
        }
    }

    private void OpenResendModal(string shortId)
    {
        resendShortId = shortId;
        resendEmails = "";
        resendMessage = "";
        resendError = null;
        resendSuccess = false;
        showResendModal = true;
    }

    private void CloseResendModal()
    {
        showResendModal = false;
        resendShortId = "";
        resendEmails = "";
        resendMessage = "";
        resendError = null;
        resendSuccess = false;
    }

    private async Task SendResendEmails()
    {
        if (string.IsNullOrWhiteSpace(resendEmails))
        {
            resendError = "At least one recipient email is required";
            return;
        }

        // Parse and validate emails
        var emails = resendEmails
            .Split(new[] { ',', ';', '\n', '\r' }, StringSplitOptions.RemoveEmptyEntries)
            .Select(e => e.Trim())
            .Where(e => !string.IsNullOrWhiteSpace(e))
            .Distinct()
            .ToList();

        if (!emails.Any())
        {
            resendError = "At least one valid email is required";
            return;
        }

        // Basic email validation
        var invalidEmails = emails.Where(e => !e.Contains('@') || !e.Contains('.')).ToList();
        if (invalidEmails.Any())
        {
            resendError = $"Invalid email format: {string.Join(", ", invalidEmails)}";
            return;
        }

        isResending = true;
        resendError = null;
        resendSuccess = false;
        StateHasChanged();

        var failedEmails = new List<string>();
        var successEmails = new List<string>();

        try
        {
            foreach (var email in emails)
            {
                // Use JS interop to make the API call from the browser (includes auth cookies)
                var result = await JSRuntime.InvokeAsync<EmailResult>("apiInterop.sendShareEmail",
                    resendShortId, email, "", resendMessage);

                if (result.Success)
                {
                    successEmails.Add(email);
                }
                else
                {
                    failedEmails.Add(email);
                }
            }

            if (successEmails.Any())
            {
                resendSuccess = true;
                await JSRuntime.InvokeVoidAsync("clipboardInterop.showToast",
                    $"Email sent to {successEmails.Count} recipient(s)", "success");

                if (failedEmails.Any())
                {
                    resendError = $"Failed to send to: {string.Join(", ", failedEmails)}";
                }
                else
                {
                    // Auto-close after short delay on complete success
                    await Task.Delay(1500);
                    CloseResendModal();
                }
            }
            else
            {
                resendError = "Failed to send email to any recipient";
            }
        }
        catch (Exception ex)
        {
            resendError = "Failed to send emails: " + ex.Message;
        }
        finally
        {
            isResending = false;
            StateHasChanged();
        }
    }

    private class EmailResult
    {
        public bool Success { get; set; }
        public string? Error { get; set; }
    }

    private string FormatBytes(long bytes)
    {
        if (bytes == 0) return "0 Bytes";
        var k = 1024.0;
        var sizes = new[] { "Bytes", "KB", "MB", "GB", "TB" };
        var i = (int)Math.Floor(Math.Log(bytes) / Math.Log(k));
        return $"{Math.Round(bytes / Math.Pow(k, i), 2)} {sizes[i]}";
    }

    private class ShareDto
    {
        public string Id { get; set; } = null!;
        public string ShortId { get; set; } = null!;
        public string? RecipientEmail { get; set; }
        public string? RecipientName { get; set; }
        public DateTime CreatedAt { get; set; }
        public DateTime ExpiresAt { get; set; }
        public int Downloads { get; set; }
        public int FileCount { get; set; }
        public long TotalSize { get; set; }
    }
}
