@using Microsoft.JSInterop
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation

@if (IsVisible)
{
    <div class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center p-4 z-50 modal-backdrop">
        <div class="bg-white rounded-lg max-w-2xl w-full max-h-[90vh] overflow-y-auto modal-content">
            <!-- Header -->
            <div class="border-b-2 border-[#660000] p-6">
                <div class="flex items-center justify-between">
                    <h2 class="text-2xl font-bold text-[#660000]">
                        @(emailSent ? "Email Sent!" : "Share Your Files")
                    </h2>
                    <button @onclick="Close" class="text-gray-400 hover:text-gray-600">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                        </svg>
                    </button>
                </div>
            </div>

            <!-- Content -->
            <div class="p-6 space-y-6">
                @if (emailSent)
                {
                    <div class="space-y-4">
                        <div class="p-4 bg-green-50 border border-green-200 rounded-lg">
                            <p class="text-green-800">
                                @if (sentToEmails.Count == 1)
                                {
                                    <span>Your share link has been sent to @sentToEmails[0]</span>
                                }
                                else
                                {
                                    <span>Your share link has been sent to @sentToEmails.Count recipients:</span>
                                    <ul class="mt-2 list-disc list-inside text-sm">
                                        @foreach (var email in sentToEmails)
                                        {
                                            <li>@email</li>
                                        }
                                    </ul>
                                }
                            </p>
                        </div>
                        <div class="text-center">
                            <button @onclick="Close"
                                    class="px-6 py-2 bg-[#660000] text-white rounded-lg hover:bg-black">
                                Done
                            </button>
                        </div>
                    </div>
                }
                else
                {
                    <!-- Share Link Display -->
                    <div class="space-y-2">
                        <label class="block text-sm font-medium text-gray-700">Share Link</label>
                        <div class="flex gap-2">
                            <input type="text"
                                   value="@shareUrl"
                                   readonly
                                   class="flex-1 px-4 py-2 border border-gray-300 rounded-lg bg-gray-50 text-sm" />
                            <button @onclick="CopyLink"
                                    class="px-4 py-2 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 whitespace-nowrap">
                                @(linkCopied ? "Copied!" : "Copy Link")
                            </button>
                        </div>
                        <p class="text-xs text-gray-500">This link will expire in 30 days</p>
                    </div>

                    <div class="border-t pt-6">
                        <h3 class="text-lg font-semibold mb-4">Send via Email (Optional)</h3>

                        <div class="space-y-4">
                            <!-- Recipient Emails -->
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">
                                    Recipient Email(s) *
                                </label>
                                <textarea @bind="recipientEmails"
                                          placeholder="recipient1@example.com, recipient2@example.com"
                                          rows="2"
                                          class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#660000] focus:border-transparent"></textarea>
                                <p class="text-xs text-gray-500 mt-1">Separate multiple email addresses with commas</p>
                            </div>

                            <!-- Message -->
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">
                                    Message (Optional)
                                </label>
                                <textarea @bind="message"
                                          placeholder="Add a personal message..."
                                          rows="4"
                                          class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#660000] focus:border-transparent"></textarea>
                            </div>

                            <!-- Error Message -->
                            @if (!string.IsNullOrEmpty(errorMessage))
                            {
                                <div class="p-4 bg-red-50 border border-red-200 rounded-lg">
                                    <p class="text-red-800 text-sm">@errorMessage</p>
                                </div>
                            }

                            <!-- Buttons -->
                            <div class="flex gap-3">
                                <button @onclick="SendEmails"
                                        disabled="@(isSending || string.IsNullOrWhiteSpace(recipientEmails))"
                                        class="flex-1 bg-[#660000] text-white py-3 px-6 rounded-lg font-semibold hover:bg-black disabled:opacity-50 disabled:cursor-not-allowed">
                                    @(isSending ? "Sending..." : "Send Email")
                                </button>
                                <button @onclick="Close"
                                        class="px-6 py-3 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300">
                                    Skip
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public bool IsVisible { get; set; }

    [Parameter]
    public string ShortId { get; set; } = "";

    [Parameter]
    public EventCallback OnClose { get; set; }

    private string shareUrl => $"{Navigation.BaseUri}s/{ShortId}";

    private string recipientEmails = "";
    private string message = "";
    private bool isSending = false;
    private bool emailSent = false;
    private bool linkCopied = false;
    private string? errorMessage;
    private List<string> sentToEmails = new();

    private async Task CopyLink()
    {
        try
        {
            var success = await JSRuntime.InvokeAsync<bool>("clipboardInterop.copyToClipboard", shareUrl);
            if (success)
            {
                linkCopied = true;
                await JSRuntime.InvokeVoidAsync("clipboardInterop.showToast", "Link copied to clipboard!", "success");
                StateHasChanged();

                // Reset after 2 seconds
                await Task.Delay(2000);
                linkCopied = false;
                StateHasChanged();
            }
        }
        catch (Exception)
        {
            await JSRuntime.InvokeVoidAsync("clipboardInterop.showToast", "Failed to copy link", "error");
        }
    }

    private async Task SendEmails()
    {
        if (string.IsNullOrWhiteSpace(recipientEmails))
        {
            errorMessage = "At least one recipient email is required";
            return;
        }

        // Parse and validate emails
        var emails = recipientEmails
            .Split(new[] { ',', ';', '\n', '\r' }, StringSplitOptions.RemoveEmptyEntries)
            .Select(e => e.Trim())
            .Where(e => !string.IsNullOrWhiteSpace(e))
            .Distinct()
            .ToList();

        if (!emails.Any())
        {
            errorMessage = "At least one valid email is required";
            return;
        }

        // Basic email validation
        var invalidEmails = emails.Where(e => !e.Contains('@') || !e.Contains('.')).ToList();
        if (invalidEmails.Any())
        {
            errorMessage = $"Invalid email format: {string.Join(", ", invalidEmails)}";
            return;
        }

        isSending = true;
        errorMessage = null;
        StateHasChanged();

        var failedEmails = new List<string>();
        var successEmails = new List<string>();

        try
        {
            foreach (var email in emails)
            {
                // Use JS interop to make the API call from the browser (includes auth cookies)
                var result = await JSRuntime.InvokeAsync<EmailResult>("apiInterop.sendShareEmail",
                    ShortId, email, "", message);

                if (result.Success)
                {
                    successEmails.Add(email);
                }
                else
                {
                    failedEmails.Add(email);
                }
            }

            if (successEmails.Any())
            {
                sentToEmails = successEmails;
                emailSent = true;

                if (failedEmails.Any())
                {
                    errorMessage = $"Failed to send to: {string.Join(", ", failedEmails)}";
                }
            }
            else
            {
                errorMessage = "Failed to send email to any recipient";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Failed to send emails: " + ex.Message;
        }
        finally
        {
            isSending = false;
            StateHasChanged();
        }
    }

    private class EmailResult
    {
        public bool Success { get; set; }
        public string? Error { get; set; }
    }

    private async Task Close()
    {
        // Reset state
        recipientEmails = "";
        message = "";
        emailSent = false;
        linkCopied = false;
        errorMessage = null;
        sentToEmails = new();

        await OnClose.InvokeAsync();
    }
}
