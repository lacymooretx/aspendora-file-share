# Aspendora File Share Environment Variables
# Copy this file to .env and fill in the actual values

# Database
POSTGRES_PASSWORD=your_secure_password_here
ConnectionStrings__DefaultConnection=Host=postgres;Port=5432;Database=fileshare;Username=fileshare;Password=your_secure_password_here

# Azure AD
AzureAd__ClientId=your_client_id_here
AzureAd__ClientSecret=your_client_secret_here

# S3 Storage (Backblaze B2)
S3__AccessKey=your_access_key_here
S3__SecretKey=your_secret_key_here

# SMTP2GO Email
Smtp2Go__ApiKey=your_api_key_here
